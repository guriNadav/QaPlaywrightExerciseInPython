# Python & Playwright .gitignore
# -------------------------------------------------
# Byte‑code artifacts
__pycache__/
*.py[cod]

# Virtual‑environment directories (adjust if you use a different name)
.venv/
venv/
env/

# Pytest cache & coverage reports
.pytest_cache/
.coverage
htmlcov/

# mypy static‑type checker cache
.mypy_cache/

# Packaging artefacts
*.egg-info/
build/
dist/

# OS‑specific files
.DS_Store
Thumbs.db

# Playwright specific (keep the ones that are generated by the library)
playwright/.cache/
playwright/.auth/
playwright-report/
# Allure reports (generated locally)
allure-results/
allure-report/

.env
